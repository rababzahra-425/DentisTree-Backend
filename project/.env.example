# Copy this file to .env and fill in real values. Never commit .env.

# # ── Django Core ──────────────────────────────────────────────────────────────
# DJANGO_SECRET_KEY=your-secret-key-here
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# # ── CORS / CSRF ───────────────────────────────────────────────────────────────
# # Comma-separated list of your frontend origins
# DJANGO_CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# # ── MongoDB ───────────────────────────────────────────────────────────────────
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# # ── Email ─────────────────────────────────────────────────────────────────────
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=Your Clinic Name <your-email@gmail.com>


DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com

EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Your App <your-email@gmail.com>

DJANGO_CORS_ORIGINS=https://yourfrontend.com

MONGO_DB_NAME=your-db-name
MONGO_HOST=your-mongodb-connection-string